# MongoDB connection (default: mongodb://localhost:27017)
MONGODB_URI=mongodb://localhost:27017
# Auth database name (default: auth)
MONGODB_AUTH_DB=auth

# Google OAuth (for Sign up / Sign in with Google). Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=22190957011-77njsstbfp4lp9r9f3g7b2lgdirs3gcf.apps.googleusercontent.com

# JWT secret for tokens
JWT_SECRET=my-jwt-secret-change-in-production

# Server port (default: 5000)
PORT=5000
